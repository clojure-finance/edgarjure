#!/usr/bin/env python3
"""
Pre-commit hook: reject Markdown doc files that contain encoding artifacts.

The CHANGELOG and PROJECT_SUMMARY use Unicode em-dashes (—, U+2014) and
other non-ASCII characters as separators.  Shell tools like `sed` can corrupt
these to a literal ASCII question mark (?) when inserting text via append
commands with shell escaping.  This hook catches that corruption before it
lands in git.

Pattern detected: a non-whitespace character followed by space-?-space
followed by a non-whitespace character, e.g.:
    `edgar.financials` ? quarterly and LTM derivation
"""

import subprocess
import sys
import re

CHECKED_FILES = ["CHANGELOG.md", "PROJECT_SUMMARY.md", "README.md"]

def get_staged_content(filename):
    """Return the staged content of a file, or None if not staged."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only"],
        capture_output=True, text=True
    )
    if filename not in result.stdout:
        return None

    result = subprocess.run(
        ["git", "show", f":{filename}"],
        capture_output=True
    )
    if result.returncode != 0:
        return None
    try:
        return result.stdout.decode("utf-8")
    except UnicodeDecodeError:
        return None

def check_for_artifacts(text):
    """
    Return a list of (line_number, line) tuples where encoding artifacts
    were detected.  Artifacts are ASCII ? characters used as em-dash
    substitutes.

    Looks for: non-whitespace, space, ?, space, non-whitespace
    """
    artifact_pattern = re.compile(r'\S \? \S')
    bad_lines = []
    for i, line in enumerate(text.splitlines(), start=1):
        if artifact_pattern.search(line):
            bad_lines.append((i, line))
    return bad_lines

def main():
    all_bad = {}

    for filename in CHECKED_FILES:
        content = get_staged_content(filename)
        if content is None:
            continue
        bad = check_for_artifacts(content)
        if bad:
            all_bad[filename] = bad

    if not all_bad:
        sys.exit(0)

    print("COMMIT REJECTED: Markdown files contain encoding artifacts.", file=sys.stderr)
    print("", file=sys.stderr)
    print("Em-dashes (\u2014) have been corrupted to ASCII '?' in the following lines:", file=sys.stderr)
    print("", file=sys.stderr)
    for filename, bad_lines in all_bad.items():
        print(f"  {filename}:", file=sys.stderr)
        for lineno, line in bad_lines:
            print(f"    Line {lineno}: {line}", file=sys.stderr)
        print("", file=sys.stderr)
    print("Fix: replace ' ? ' with ' \u2014 ' (U+2014 em-dash) in the affected lines.", file=sys.stderr)
    print("     Em-dash character to copy: \u2014", file=sys.stderr)
    print("", file=sys.stderr)
    print("Root cause: `sed -i` append commands mangle Unicode characters.", file=sys.stderr)
    print("Prevention: use Python for all multi-line doc insertions.", file=sys.stderr)
    sys.exit(1)

if __name__ == "__main__":
    main()
